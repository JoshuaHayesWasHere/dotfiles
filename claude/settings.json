{
  "theme": "dark",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(source venv/bin/activate)",
      "Bash(pip install:*)",
      "Bash(ls:*)",
      "Bash(git log:*)",
      "Bash(venv/bin/python:*)"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/joshua/.claude/statusline.sh",
    "refreshInterval": 1
  },
  "verbose": true,
  "agentPushNotifEnabled": true
}
