# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Configure Path
export PATH=$(echo "$PATH" | tr ':' '\n' | awk '!seen[$0]++' | tr '\n' ':')

ZSH_THEME="powerlevel10k/powerlevel10k"


#ZSH_THEME="catppuccin"
#CATPPUCCIN_FLAVOR="mocha" # Required! Options: mocha, flappe, macchiato, latte
#CATPPUCCIN_SHOW_TIME=true  # Optional! If set to true, this will add the current time to the prompt.

# --- Core performance & safety (WSL-friendly) ---
DISABLE_AUTO_UPDATE="true"
DISABLE_MAGIC_FUNCTIONS="true"
ZSH_DISABLE_COMPFIX="true"

# --- Oh My Zsh location ---
export ZSH="$HOME/.oh-my-zsh"

# --- Completion system (robust) ---
autoload -Uz compinit
compinit -u

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' rehash true

# --- History behavior ---
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt SHARE_HISTORY
setopt INC_APPEND_HISTORY

# --- Keybindings (prefix-based history search) ---
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# --- Plugins ---
plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
  aws
)

# --- Load Oh My Zsh ---
source $ZSH/oh-my-zsh.sh

## set colors for LS_COLORS
eval `dircolors ~/.dircolors`
export PATH="$HOME/.local/bin:$PATH"

# --- NVM (Node Version Manager) ---
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Smarter cd command (must load after oh-my-zsh to override cd)
eval "$(zoxide init zsh)"

# --- Modern CLI tools ---
alias ls='eza --icons'
alias ll='eza -l --icons --git'
alias la='eza -la --icons --git'
alias lt='eza --tree --icons'
alias cat='batcat'
alias bat='batcat'
alias grep='rg'
alias cd='z'
alias ci='zi'

# AWS profile switchers (SSO)
awslogin() {
  local profile="$1"
  export AWS_PROFILE="$profile"

  # Fast path: already logged in.
  if aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
    aws sts get-caller-identity --profile "$profile"
    return 0
  fi

  # Prefer PKCE (no code).
  if aws sso login --profile "$profile"; then
    aws sts get-caller-identity --profile "$profile"
    return 0
  fi

  # Fallback: device code.
  aws sso login --profile "$profile" --use-device-code
  aws sts get-caller-identity --profile "$profile"
}

awsdev()   { awslogin sandbox; }
awsadmin() { awslogin admin; }
awslrpdev()     { awslogin lrp-sandbox; }
awslrpadmin()   { awslogin lrp-admin; }

awswho() {
  aws sts get-caller-identity --profile "${AWS_PROFILE:-default}"
}

awslogout() {
  aws sso logout >/dev/null 2>&1
  unset AWS_PROFILE
}

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Configure browser (wslview from wslu package)
export BROWSER=wslview

# Winnifred fullstack dev runner
alias winnifred='python3 ~/projects/Winnifred/scripts/run-local.py'
