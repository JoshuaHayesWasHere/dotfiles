# ~/.zshrc — Arch + Hyprland (KooL Dots base, customized)

# Dedupe PATH
export PATH=$(echo "$PATH" | tr ':' '\n' | awk '!seen[$0]++' | tr '\n' ':')

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="bureau"

plugins=(
    git
    archlinux
    zsh-autosuggestions
    zsh-syntax-highlighting
    aws
)

source $ZSH/oh-my-zsh.sh
# https://github.com/ohmyzsh/ohmyzsh/tree/master/plugins/archlinux

# History
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt SHARE_HISTORY
setopt INC_APPEND_HISTORY
setopt appendhistory

# Prefix-based history search
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# LS_COLORS via dircolors (if present)
[ -r "$HOME/.dircolors" ] && eval "$(dircolors "$HOME/.dircolors")"

# Pokemon-colorscripts + fastfetch greeting
# https://gitlab.com/phoneybadger/pokemon-colorscripts
if command -v pokemon-colorscripts >/dev/null 2>&1 && command -v fastfetch >/dev/null 2>&1; then
    pokemon-colorscripts --no-title -s -r | fastfetch -c $HOME/.config/fastfetch/config-pokemon.jsonc --logo-type file-raw --logo-height 10 --logo-width 5 --logo -
fi

# Modern CLI replacements
alias ls='eza --icons'
alias ll='eza -l --icons --git'
alias la='eza -la --icons --git'
alias lt='eza --tree --icons'
alias cat='bat'
alias grep='rg'
alias clip='wl-copy'
dclip() { { print -- "\$ ${(q-)@}"; "$@" 2>&1 } | tee >(wl-copy --primary); return ${pipestatus[1]} }

# fzf (CTRL-R fuzzy history)
command -v fzf >/dev/null 2>&1 && source <(fzf --zsh)

# AWS SSO profile switchers
awslogin() {
    local profile="$1"
    export AWS_PROFILE="$profile"

    if aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
        aws sts get-caller-identity --profile "$profile"
        return 0
    fi

    if aws sso login --profile "$profile"; then
        aws sts get-caller-identity --profile "$profile"
        return 0
    fi

    aws sso login --profile "$profile" --use-device-code
    aws sts get-caller-identity --profile "$profile"
}

awsdev()      { awslogin sandbox; }
awsadmin()    { awslogin admin; }
awslrpdev()   { awslogin lrp-sandbox; }
awslrpadmin() { awslogin lrp-admin; }

awswho() {
    aws sts get-caller-identity --profile "${AWS_PROFILE:-default}"
}

awslogout() {
    aws sso logout >/dev/null 2>&1
    unset AWS_PROFILE
}

# Project shortcuts
alias winnifred='python3 ~/repos/Winnifred/scripts/run-local.py'

# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# PATH
export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# zoxide — must initialize last so its hooks aren't overridden by anything
# loaded later (NVM, PATH-dependent tools, etc.)
if command -v zoxide >/dev/null 2>&1; then
    alias ci='cdi'
    eval "$(zoxide init --cmd cd zsh)"
fi
