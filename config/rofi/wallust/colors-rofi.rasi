 /* wallust template - colors-rofi */

* {
active-background: #F7758D;
active-foreground: #C4E7E1;
normal-background: #1A1A1D;
normal-foreground: #C4E7E1;
urgent-background: #7AA2F7;
urgent-foreground: #C4E7E1;

alternate-active-background: #4E5174;
alternate-active-foreground: #C4E7E1;
alternate-normal-background: #1A1A1D;
alternate-normal-foreground: #C4E7E1;
alternate-urgent-background: #1A1A1D;
alternate-urgent-foreground: #C4E7E1;

selected-active-background: #7AA2F7;
selected-active-foreground: #C4E7E1;
selected-normal-background: #7AA2F7;
selected-normal-foreground: #C4E7E1;
